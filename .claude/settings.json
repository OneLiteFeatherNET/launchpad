{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm generate)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm exec eslint .)",
      "Bash(pnpm seo:lighthouse)",
      "Bash(pnpm seo:check)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git log:*)"
    ]
  }
}
